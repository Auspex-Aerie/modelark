# Python
.venv/
.venv-dev/
__pycache__/
*.egg-info/
build/
dist/

# Catalog: the DuckDB file is a rebuildable cache; JSONL export under
# catalog/export/ is the versioned source of truth and IS committed.
catalog/*.duckdb
catalog/*.duckdb.wal
catalog/*.duckdb.bak
catalog/*.sqlite
catalog/*.sqlite-wal
catalog/*.sqlite-shm

# Local git-annex map location (machine-specific; regenerated by ensure_library)
catalog/library.json

# Regenerable diagnostic output from filtering runs
catalog/exclusions/

# Model bytes never go in git — git-annex tracks them on the drive fleet.
models/
staging/

# StreamZNN test fixtures: sampled/synthetic weight bytes, not committed (no third-party tensors
# in the repo). The suite regenerates a deterministic synthetic golden when absent (DEF-014-adjacent:
# ship a real golden sampled from our own ParameterGolfLLM). Also keep the operator's dropped docs out.
tests/fixtures/*.bin
/RightHandSpace.docx
/.~lock.RightHandSpace.docx#

# Scratch
*.output
*.log

# runtime logs (DEC-023)
logs/

# Playwright MCP verification artifacts
.playwright-mcp/
catalog/last_fill.json

# public repo: ship only the model catalog; a user's own hardware/fill exports stay local
catalog/export/drives.jsonl
catalog/export/files.jsonl
catalog/export/replicas.jsonl
catalog/export/verifications.jsonl
